.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.coverage

# Virtual environments
.venv/
venv/

# Environment variables
.env
.env.*
!.env.example

# Node modules
node_modules/

# uv
.uv/

# Generated outputs (keep .gitkeep placeholders)
plans/*
!/plans/.gitkeep

outputs/slides/*
outputs/demos/*
outputs/ai-projects/*
outputs/hackathons/*
!outputs/slides/.gitkeep
!outputs/demos/.gitkeep
!outputs/ai-projects/.gitkeep
!outputs/hackathons/.gitkeep

.img_cache
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
